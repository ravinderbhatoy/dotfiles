[module/launcher]
type = custom/text
format = 
format-padding = 1
format-font = 2
format-foreground = ${colors.primary}

[module/i3]
type = internal/i3
index-sort = true
wrapping-scroll = false
enable-scroll = true

format = <label-state> <label-mode>
format-padding = 1
label-mode = " %mode%"
label-mode-padding = 1
label-mode-foreground = ${colors.aurora-orange}

label-focused = %index%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.window-background}
label-focused-padding = 1

label-unfocused = %index%
label-unfocused-padding = 1
label-unfocused-foreground = ${colors.foreground}

label-visible = %index%
label-visible-background = ${colors.background-alt}
label-visible-padding = 1

label-urgent = %index%
label-urgent-background = ${colors.primary}
label-urgent-padding = 1

[module/date]
type = internal/date
interval = 1.0
time = %I:%M %p
time-alt = %I:%M %p
date = %A
date-alt = %d-%m-%Y
label = %date% %time%
label-font = 0
label-foreground = ${colors.foreground}
format = <label>
format-padding = 1
format-prefix-foreground = ${colors.aurora-yellow}
format-prefix-padding = 1
format-prefix-font = 0

[module/pulseaudio]
type = internal/pulseaudio
use-ui-max = false
click-right = pavucontrol

format-volume = <label-volume>
format-volume-prefix = 
format-volume-prefix-foreground = ${colors.primary}
format-volume-prefix-padding = 1
label-volume =  %percentage%%
label-volume-foreground = ${colors.foreground}

format-muted = <label-muted>
format-muted-prefix = 󰝟
format-muted-prefix-foreground = ${colors.disabled}
format-muted-prefix-font = 2
format-muted-padding = 1
label-muted =  Mute
label-muted-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 2
format = <label>
format-padding = 1
format-prefix = 
format-prefix-font = 2
format-prefix-foreground = ${colors.secondary}
format-prefix-padding = 1
label =  %percentage_used%%
label-foreground = ${colors.foreground}

[module/cpu]
type = internal/cpu
interval = 1
format = <label>
format-prefix = 
format-prefix-font = 2
format-prefix-foreground = ${colors.aurora-violet}
format-prefix-padding = 1
label =  %percentage%%
label-foreground = ${colors.foreground}

[module/network]
type = internal/network
interface = wlan0
interval = 3.0
unknown-as-up = true

format-connected = <label-connected>
format-connected-padding = 1
format-connected-prefix = 󰤨
format-connected-prefix-foreground = ${colors.aurora-green}
format-connected-prefix-padding = 1
format-connected-foreground = ${colors.foreground}
label-connected =  %signal%% %essid%
label-connected-foreground = ${colors.foreground}

format-disconnected = <label-disconnected>
format-disconnected-padding = 1
format-disconnected-prefix = 󰤮
format-disconnected-prefix-foreground = ${colors.disabled}
format-disconnected-prefix-padding = 1
format-disconnected-foreground = ${colors.foreground}
label-disconnected =  offline
label-disconnected-foreground = ${colors.foreground}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ACAD
full-at = 99
poll-interval = 5

format-charging = <label-charging>
format-charging-padding = 1
format-charging-prefix = 
label-charging = %percentage%%
format-charging-prefix-foreground = ${colors.aurora-green}
format-charging-prefix-padding = 1
label-charging-foreground = ${colors.aurora-green}

format-discharging = <label-discharging>
format-discharging-prefix = 
format-discharging-padding = 1
format-discharging-prefix-foreground = ${colors.aurora-orange}
format-discharging-prefix-padding = 1
label-discharging =  %percentage%%
label-discharging-foreground = ${colors.foreground}

format-full = <label-full>
format-full-padding = 1
format-full-prefix = 
format-full-prefix-foreground = ${colors.aurora-green}
format-full-prefix-padding = 1
label-full =  %percentage%%
label-full-foreground = ${colors.foreground}

[module/sessionLogout]
type = custom/text
format = <label>
format-padding = 1
label = "⏻"
label-foreground = ${colors.aurora-orange}
label-font = 3
click-left = ~/.config/polybar/powermenu.sh
