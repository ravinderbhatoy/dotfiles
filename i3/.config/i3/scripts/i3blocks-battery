#!/bin/sh

POWER_SUPPLY_DIR="${POWER_SUPPLY_DIR:-/sys/class/power_supply}"

is_ac_online() {
    for supply in "$POWER_SUPPLY_DIR"/*; do
        [ -d "$supply" ] || continue
        [ "$(cat "$supply/type" 2>/dev/null)" = "Mains" ] || continue
        [ "$(cat "$supply/online" 2>/dev/null)" = "1" ] && return 0
    done

    return 1
}

total=0
count=0
has_charging=0
has_discharging=0
has_not_charging=0
has_unknown=0

for supply in "$POWER_SUPPLY_DIR"/BAT*; do
    [ -d "$supply" ] || continue

    capacity=$(cat "$supply/capacity" 2>/dev/null)
    case "$capacity" in
        ''|*[!0-9]*) continue ;;
    esac

    total=$((total + capacity))
    count=$((count + 1))

    case "$(cat "$supply/status" 2>/dev/null)" in
        Charging) has_charging=1 ;;
        Discharging) has_discharging=1 ;;
        Not\ charging) has_not_charging=1 ;;
        Full) : ;;
        *) has_unknown=1 ;;
    esac
done

[ "$count" -gt 0 ] || {
    printf '\n'
    exit 0
}

capacity=$((total / count))

if [ "$has_discharging" -eq 1 ]; then
    status="Discharging"
elif [ "$has_charging" -eq 1 ]; then
    status="Charging"
elif [ "$has_not_charging" -eq 1 ] && ! is_ac_online; then
    status="Discharging"
elif [ "$has_unknown" -eq 1 ] && ! is_ac_online; then
    status="Discharging"
elif [ "$has_not_charging" -eq 1 ]; then
    status="Not charging"
elif [ "$has_unknown" -eq 1 ]; then
    status="Unknown"
else
    status="Full"
fi

case "$status" in
    Charging) icon="" ;;
    Full) icon="" ;;
    Not\ charging) icon="" ;;
    *)
        if [ "$capacity" -ge 90 ]; then
            icon=""
        elif [ "$capacity" -ge 60 ]; then
            icon=""
        elif [ "$capacity" -ge 30 ]; then
            icon=""
        elif [ "$capacity" -ge 15 ]; then
            icon=""
        else
            icon=""
        fi
        ;;
esac

printf '%s %s%%\n' "$icon" "$capacity"
