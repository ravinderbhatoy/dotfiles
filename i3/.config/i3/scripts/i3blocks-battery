#!/bin/sh

for supply in /sys/class/power_supply/BAT*; do
    [ -d "$supply" ] || continue

    capacity=$(cat "$supply/capacity" 2>/dev/null)
    status=$(cat "$supply/status" 2>/dev/null)

    case "$status" in
        Charging) icon="яГз" ;;
        Full) icon="яЙА" ;;
        *)
            if [ "${capacity:-0}" -ge 90 ]; then
                icon="яЙА"
            elif [ "${capacity:-0}" -ge 60 ]; then
                icon="яЙБ"
            elif [ "${capacity:-0}" -ge 30 ]; then
                icon="яЙВ"
            elif [ "${capacity:-0}" -ge 15 ]; then
                icon="яЙГ"
            else
                icon="яЙД"
            fi
            ;;
    esac

    printf '%s %s%%\n' "$icon" "$capacity"
    exit 0
done

printf '\n'
