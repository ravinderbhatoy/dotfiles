#!/bin/sh

connected=$(nmcli -t -f TYPE,STATE,CONNECTION device 2>/dev/null | awk -F: '$2=="connected"{print $1":"$3; exit}')

if [ -z "$connected" ]; then
    printf 'пҒұ offline\n'
    exit 0
fi

type=${connected%%:*}
name=${connected#*:}

case "$type" in
    wifi)
        printf 'пҮ« %s\n' "$name"
        ;;
    ethernet)
        printf 'пһ– %s\n' "$name"
        ;;
    *)
        printf 'п„Ё %s\n' "$name"
        ;;
esac
