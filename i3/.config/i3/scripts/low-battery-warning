#!/bin/sh

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}"
STATE_FILE="$STATE_DIR/low-battery-warning.state"
LOG_FILE="$STATE_DIR/low-battery-warning.log"
POWER_SUPPLY_DIR="${POWER_SUPPLY_DIR:-/sys/class/power_supply}"
CHECK_INTERVAL=60
WARN_LEVEL=20
CRITICAL_LEVEL=10
STATE_TTL=900

is_ac_online() {
    for supply in "$POWER_SUPPLY_DIR"/*; do
        [ -d "$supply" ] || continue
        [ "$(cat "$supply/type" 2>/dev/null)" = "Mains" ] || continue
        [ "$(cat "$supply/online" 2>/dev/null)" = "1" ] && return 0
    done

    return 1
}

get_battery_summary() {
    total=0
    count=0
    has_charging=0
    has_discharging=0
    has_not_charging=0
    has_unknown=0

    for supply in "$POWER_SUPPLY_DIR"/BAT*; do
        [ -d "$supply" ] || continue
        capacity=$(cat "$supply/capacity" 2>/dev/null)
        case "$capacity" in
            ''|*[!0-9]*) continue ;;
        esac

        total=$((total + capacity))
        count=$((count + 1))

        case "$(cat "$supply/status" 2>/dev/null)" in
            Charging) has_charging=1 ;;
            Discharging) has_discharging=1 ;;
            Not\ charging) has_not_charging=1 ;;
            Full) : ;;
            *) has_unknown=1 ;;
        esac
    done

    [ "$count" -gt 0 ] || return 1

    capacity=$((total / count))
    if [ "$has_discharging" -eq 1 ]; then
        status="Discharging"
    elif [ "$has_charging" -eq 1 ]; then
        status="Charging"
    elif [ "$has_not_charging" -eq 1 ] && ! is_ac_online; then
        status="Discharging"
    elif [ "$has_unknown" -eq 1 ] && ! is_ac_online; then
        status="Discharging"
    elif [ "$has_not_charging" -eq 1 ]; then
        status="Not charging"
    elif [ "$has_unknown" -eq 1 ]; then
        status="Unknown"
    else
        status="Full"
    fi

    printf '%s|%s\n' "$capacity" "$status"
}

send_warning() {
    level="$1"
    urgency="$2"
    timeout="$3"
    message="Battery is at ${level}%. Plug in the charger."
    title="Low battery"

    if command -v notify-send >/dev/null 2>&1; then
        if notify-send -u "$urgency" -t "$timeout" "$title" "$message" 2>>"$LOG_FILE"; then
            return 0
        fi
    fi

    if command -v i3-nagbar >/dev/null 2>&1; then
        i3-nagbar -t warning -m "$title: $message" >/dev/null 2>>"$LOG_FILE" &
        return 0
    fi

    if command -v xmessage >/dev/null 2>&1; then
        xmessage -center "$title: $message" >/dev/null 2>>"$LOG_FILE" &
        return 0
    fi

    printf '%s %s\n' "$(date '+%F %T')" "$title: $message" >> "$LOG_FILE"
}

last_band=""
last_time=0

if [ -f "$STATE_FILE" ]; then
    IFS='|' read -r last_band last_time < "$STATE_FILE"
fi

while :; do
    battery_summary=$(get_battery_summary) || exit 0
    capacity=${battery_summary%%|*}
    status=${battery_summary#*|}
    now=$(date +%s)

    case "$status" in
        Charging|Full|Not\ charging)
            last_band=""
            last_time=0
            : > "$STATE_FILE"
            sleep "$CHECK_INTERVAL"
            continue
            ;;
    esac

    if [ -z "$capacity" ]; then
        sleep "$CHECK_INTERVAL"
        continue
    fi

    current_band=""
    urgency="normal"
    timeout=5000

    if [ "$capacity" -le "$CRITICAL_LEVEL" ]; then
        current_band="critical"
        urgency="critical"
        timeout=0
    elif [ "$capacity" -le "$WARN_LEVEL" ]; then
        current_band="warning"
    fi

    if [ -n "$current_band" ] && {
        [ "$last_band" != "$current_band" ] ||
        [ -z "$last_time" ] ||
        [ $((now - last_time)) -ge "$STATE_TTL" ]
    }; then
        send_warning "$capacity" "$urgency" "$timeout"
        last_band="$current_band"
        last_time="$now"
        printf '%s|%s\n' "$last_band" "$last_time" > "$STATE_FILE"
    elif [ -z "$current_band" ] && [ -n "$last_band" ]; then
        last_band=""
        last_time=0
        : > "$STATE_FILE"
    elif [ "$current_band" = "warning" ] && [ "$last_band" = "critical" ]; then
        last_band="$current_band"
        last_time="$now"
        printf '%s|%s\n' "$last_band" "$last_time" > "$STATE_FILE"
    elif [ "$capacity" -gt "$WARN_LEVEL" ] && [ -n "$last_band" ]; then
        last_band=""
        last_time=0
        : > "$STATE_FILE"
    fi

    sleep "$CHECK_INTERVAL"
done
