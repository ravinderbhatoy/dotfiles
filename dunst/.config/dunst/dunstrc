[global]
    monitor = 0
    follow = mouse
    width = 360
    height = (0, 140)
    origin = top-right
    offset = (18, 34)
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 8
    progress_bar_corner_radius = 4
    progress_bar_frame_width = 0

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 2
    frame_color = "#D19576"
    corner_radius = 0

    icon_corner_radius = 0
    icon_position = left
    min_icon_size = 28
    max_icon_size = 48

    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false

    font = JetBrainsMono Nerd Font Mono 10
    line_height = 4
    word_wrap = yes

    sort = yes
    shrink = no
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1F2430"
    foreground = "#C8D3F5"
    frame_color = "#D19576"
    timeout = 4

[urgency_normal]
    background = "#1B1F2A"
    foreground = "#E5E9F0"
    frame_color = "#D19576"
    highlight = "#88C0D0"
    timeout = 6

[urgency_critical]
    background = "#2B1F24"
    foreground = "#F8F8F2"
    frame_color = "#D19576"
    highlight = "#D08770"
    timeout = 0
